# Backend — Cognee Cloud + Gemini (no OpenAI needed)

COGNEE_MODE=cloud

COGNEE_CLOUD_URL=https://tenant-<id>.aws.cognee.ai

COGNEE_API_KEY=your_cognee_cloud_key

GEMINI_API_KEY=your_gemini_key

LLM_PROVIDER=gemini

LLM_MODEL=gemini/gemini-2.0-flash-exp

GITHUB_TOKEN=ghp_...

SQLITE_PATH=./code_archaeologist.db

CLONE_DIR=./repos

CORS_ORIGINS=http://localhost:3000

MAX_FILES=50



# Expert knowledge notifications (optional)

SLACK_WEBHOOK_URL=

NOTIFY_EMAIL_TO=team@example.com

NOTIFY_EMAIL_FROM=noreply@example.com

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USER=

SMTP_PASSWORD=



# Frontend

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_GITHUB_REPO=https://github.com/AviArora02-commits/code-archaeologist

