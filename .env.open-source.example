# Open-source Cognee (self-hosted) — copy to .env for docker compose

COGNEE_MODE=local

# LLM — pick one provider
GEMINI_API_KEY=your_gemini_key
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash-exp

# Or OpenAI:
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-4o-mini

GITHUB_TOKEN=

CORS_ORIGINS=http://localhost:3000
MAX_FILES=25

# Persisted inside Docker volume archaeologist_data:
# SQLITE_PATH=/data/code_archaeologist.db
# CLONE_DIR=/data/repos
# DATA_ROOT_DIRECTORY=/data/cognee_data
# SYSTEM_ROOT_DIRECTORY=/data/cognee_system
